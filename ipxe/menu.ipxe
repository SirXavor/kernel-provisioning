#!ipxe
:start
menu Infra-Server Boot Menu
item ubuntu  Instalar Ubuntu Server automaticamente
choose --default ubuntu --timeout 5000 target && goto ${target}

:ubuntu
set server 192.168.1.70:8081
set seed http://${server}/ds/${mac:hexhyp}

kernel http://${server}/vmlinuz ip=dhcp \
  url=http://${server}/ubuntu/ubuntu-24.04.4-live-server-amd64.iso \
  autoinstall \
  ds=nocloud;s=${seed}/ ---
initrd http://${server}/initrd
boot
